<section class="of-bg-deep" style="padding:100px 0 70px;">
  <div class="of-container" style="max-width:820px;">
    <h1 class="of-display of-text-white" style="font-size:clamp(36px,5vw,68px);line-height:0.98;" data-reveal>{{ page.title }}</h1>
  </div>
</section>
<section class="of-section of-bg-light">
  <div class="of-container of-rte" style="max-width:760px;" data-reveal>
    {{ page.content }}
  </div>
</section>

<style>
.of-rte { color: var(--of-ink-soft); font-size: 17px; line-height: 1.75; }
.of-rte h2, .of-rte h3 { font-family: var(--of-font-display); color: var(--of-deep); text-transform: uppercase; letter-spacing: -0.5px; margin: 40px 0 14px; }
.of-rte h2 { font-size: 28px; } .of-rte h3 { font-size: 22px; }
.of-rte p { margin: 0 0 20px; } .of-rte a { color: var(--of-orange); text-decoration: underline; }
.of-rte ul, .of-rte ol { padding-left: 22px; margin: 0 0 20px; } .of-rte li { margin-bottom: 8px; }
.of-rte img { border-radius: 6px; margin: 24px 0; }
</style>

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
