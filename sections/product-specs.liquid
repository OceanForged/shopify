<section class="of-section of-bg-light">
  <div class="of-container of-container--narrow" data-reveal>
    <h2 class="of-display of-h2" style="text-align:center;margin-bottom:40px;">{{ section.settings.heading | default: 'Specifications' }}</h2>
    <div style="display:flex;flex-direction:column;background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 12px 40px rgba(21,48,47,0.06);">
      {%- for block in section.blocks -%}
        <div style="display:flex;justify-content:space-between;gap:20px;padding:22px 28px;{% unless forloop.last %}border-bottom:1px solid #e4eae8;{% endunless %}" {{ block.shopify_attributes }}>
          <span style="font-weight:600;color:var(--of-deep);text-transform:uppercase;letter-spacing:0.5px;font-size:14px;">{{ block.settings.label }}</span>
          <span style="color:var(--of-ink-soft);text-align:right;">{{ block.settings.value }}</span>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.note != blank -%}
      <p style="font-size:13px;color:var(--of-muted);margin:22px 0 0;text-align:center;">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Specifications",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Specifications" },
    { "type": "text", "id": "note", "label": "Note", "default": "Retail, agency and bulk-order pricing available upon request." }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Construction" },
        { "type": "text", "id": "value", "label": "Value", "default": "RF-welded TPU" }
      ]
    }
  ],
  "presets": [{
    "name": "Specifications",
    "blocks": [
      { "type": "spec", "settings": { "label": "Construction", "value": "RF-welded TPU" } },
      { "type": "spec", "settings": { "label": "Closure", "value": "TRU ZIP self-healing waterproof zipper" } },
      { "type": "spec", "settings": { "label": "Protection", "value": "Waterproof. Dustproof. Sandproof." } },
      { "type": "spec", "settings": { "label": "Carry", "value": "Secure low-profile harness system" } },
      { "type": "spec", "settings": { "label": "Back Panel", "value": "Molded EVA back for support & comfort" } },
      { "type": "spec", "settings": { "label": "Inside Dimensions", "value": "Approx. 4 x 4 x 16 in, final specs confirming" } },
      { "type": "spec", "settings": { "label": "Fits", "value": "Handheld radios and other critical gear" } }
    ]
  }]
}
{% endschema %}
