{%- liquid
  assign menu = linklists[section.settings.menu]
-%}
<header class="of-header">
  <div class="of-header__inner">
    <a href="{{ routes.root_url }}" class="of-brand" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}"
             width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}"
             alt="{{ shop.name | escape }}" style="height:{{ section.settings.logo_height | default: 54 }}px;width:auto;">
      {%- else -%}
        <img src="{{ 'logo-mark-transparent.png' | asset_url }}" alt="{{ shop.name | escape }}" style="height:{{ section.settings.logo_height | default: 56 }}px;width:auto;">
      {%- endif -%}
      {%- if section.settings.show_brand_text -%}
        <span class="of-brand__type">{{ section.settings.brand_line_1 | default: 'OCEAN' }}<br>{{ section.settings.brand_line_2 | default: 'FORGED' }}</span>
      {%- endif -%}
    </a>

    <button class="of-nav__toggle" aria-label="Menu" aria-expanded="false" aria-controls="SiteNav">
      <span></span><span></span><span></span>
    </button>

    <nav id="SiteNav" class="of-nav" aria-label="Primary">
      {%- if menu != blank -%}
        {%- for link in menu.links -%}
          <a href="{{ link.url }}" class="of-nav__link"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.root_url }}" class="of-nav__link">Home</a>
        <a href="{{ routes.all_products_collection_url }}" class="of-nav__link">Product</a>
        <a href="/pages/about" class="of-nav__link">About</a>
        <a href="{{ blog.url | default: '/blogs/news' }}" class="of-nav__link">Blog</a>
        <a href="/pages/pre-sale" class="of-nav__link">Team Orders</a>
      {%- endif -%}
      <button type="button" class="of-cart-toggle" data-of-cart-open aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="of-cart-count" data-of-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
      {%- if section.settings.show_cta -%}
        <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="of-btn of-btn--primary of-btn--sm">{{ section.settings.cta_label | default: 'Product' }}</a>
      {%- endif -%}
    </nav>
  </div>
</header>

<style>
  .of-cart-toggle{position:relative;display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;padding:0;border:none;background:none;color:var(--of-on-dark-3);cursor:pointer;transition:color .18s ease;}
  .of-cart-toggle:hover{color:var(--of-orange-lt);}
  .of-cart-count{position:absolute;top:-3px;right:-4px;display:inline-flex;align-items:center;justify-content:center;min-width:17px;height:17px;padding:0 4px;border-radius:100px;background:var(--of-orange);color:#fff;font-size:10px;font-weight:800;line-height:1;}
  .of-cart-count[hidden]{display:none;}
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 34, "max": 80, "step": 2, "unit": "px", "default": 54 },
    { "type": "checkbox", "id": "show_brand_text", "label": "Show typed wordmark next to logo", "default": false },
    { "type": "text", "id": "brand_line_1", "label": "Wordmark line 1", "default": "OCEAN" },
    { "type": "text", "id": "brand_line_2", "label": "Wordmark line 2", "default": "FORGED" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "header", "content": "Call to action" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Product" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ]
}
{% endschema %}
