{%- paginate collection.products by 12 -%}
<section class="of-bg-deep" style="padding:96px 0 70px;">
  <div class="of-container of-container--wide">
    <p class="of-eyebrow" data-reveal>Ocean Forged</p>
    <h1 class="of-display of-h1 of-text-white" data-reveal>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div style="font-size:18px;color:var(--of-on-dark-2);margin:22px 0 0;max-width:56ch;line-height:1.6;" data-reveal>{{ collection.description }}</div>
    {%- endif -%}
  </div>
</section>

<section class="of-section of-bg-light">
  <div class="of-container of-container--wide">
    {%- if collection.products.size > 0 -%}
      <div class="of-grid of-grid--3">
        {%- for product in collection.products -%}
          <a href="{{ product.url }}" style="background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 12px 36px rgba(21,48,47,0.06);display:block;" data-reveal>
            <div style="aspect-ratio:1/1;{% if product.featured_media %}background:#0f2423 url('{{ product.featured_media | image_url: width: 800 }}') center/cover;{% else %}background:repeating-linear-gradient(45deg,#e4eae8,#e4eae8 14px,#edf1f0 14px,#edf1f0 28px);{% endif %}border-bottom:3px solid var(--of-orange);"></div>
            <div style="padding:24px 24px 28px;">
              <h3 style="font-family:var(--of-font-display);font-weight:800;font-size:20px;line-height:1.15;margin:0 0 8px;text-transform:uppercase;">{{ product.title }}</h3>
              <div style="display:flex;align-items:baseline;gap:10px;">
                <span style="font-weight:700;color:var(--of-deep);font-size:17px;">{{ product.price | money }}</span>
                {%- unless product.available -%}<span style="font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--of-muted);">Coming soon</span>{%- endunless -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex;justify-content:center;gap:12px;margin-top:56px;">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="of-btn of-btn--outline of-btn--sm">&larr; Prev</a>{%- endif -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="of-btn of-btn--outline of-btn--sm">Next &rarr;</a>{%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <p style="text-align:center;color:var(--of-ink-soft);font-size:18px;padding:60px 0;">No products in this collection yet.</p>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
