{%- comment -%}
  Ocean Forged — Product detail (Radio Dry Bag).
  Buy box adds a real Shopify product/variant to the global cart drawer (window.OFCart).
  Pick the product in the theme editor: Product page → Buy box → Product.
{%- endcomment -%}
{%- liquid
  assign product = section.settings.product
  assign variant = product.selected_or_first_available_variant
  assign hero_img   = 'product-worn.jpg' | asset_url
  assign bag_img    = 'studio-bag-square.png' | asset_url
  assign ocean_img  = 'ocean-hero.jpg' | asset_url
  assign img_harness = 'detail-harness.png' | asset_url
  assign img_anchor  = 'detail-anchor.png' | asset_url
  assign img_window  = 'detail-window.png' | asset_url
  if product.featured_image != blank
    assign buy_img = product.featured_image | image_url: width: 1200
  else
    assign buy_img = hero_img
  endif
-%}

<!-- ================= PRODUCT HERO ================= -->
<section class="of-bg-deep" style="padding:84px 0 0;">
  <div class="of-container">
    <h1 class="of-display of-text-white" style="font-size:clamp(48px,8vw,116px);line-height:0.88;letter-spacing:-1.5px;margin:0;text-transform:uppercase;" data-reveal>{{ section.settings.title | default: 'Radio Dry Bag' }}</h1>
    <p class="of-eyebrow" style="margin:18px 0 0;" data-reveal>{{ section.settings.eyebrow | default: 'Ocean Forged · Product 01' }}</p>
    <p class="of-pd-tagline" data-reveal>{{ section.settings.subtitle | default: 'Made by lifeguards. Built for real world rescues.' }}</p>
  </div>
</section>

<!-- ================= BUY BOX ================= -->
<section class="of-bg-deep" style="padding:56px 0 76px;">
  <div class="of-container">
    <div class="of-pd-buy">
      <div class="of-pd-buy__media" style="background-image:url('{{ buy_img }}');" data-reveal>
        <div class="of-pd-buy__tag">
          <span style="font-family:var(--of-font-body);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--of-orange-lt,#ff6a3d);">RDB-01</span>
          <span style="font-family:var(--of-font-body);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--of-on-dark-3,#8fa8a8);">Field-tested · Ocean Beach, CA</span>
        </div>
      </div>
      <div class="of-pd-buy__card" data-reveal>
        <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
          <span class="of-pd-chip of-pd-chip--solid">{% if variant.available %}In stock{% else %}Made to order{% endif %}</span>
          <span class="of-pd-chip">READY TO SHIP</span>
        </div>
        <h2 class="of-display" style="font-size:30px;margin:0 0 6px;text-transform:uppercase;letter-spacing:-0.5px;line-height:1;">{{ product.title | default: 'Radio Dry Bag' }}</h2>
        <p style="font-size:14px;color:var(--of-ink-soft);margin:0 0 20px;line-height:1.55;text-transform:uppercase;letter-spacing:0.4px;">RF-welded · submersible · cross-body harness. Made by lifeguards, built for real-world rescues.</p>
        <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:22px;">
          <span class="of-display" style="font-size:44px;color:var(--of-orange);letter-spacing:-1px;">{% if product != blank %}{{ variant.price | money }}{% else %}$110{% endif %}</span>
          <span style="font-family:var(--of-font-body);font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--of-muted);">per unit</span>
        </div>

        {%- if product != blank -%}
        <form class="of-pd-form" data-of-pd-form data-variant="{{ variant.id }}">
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:18px;">
            <span style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--of-deep);">Qty</span>
            <div class="of-step" style="border:2px solid rgba(21,48,47,0.2);border-radius:6px;overflow:hidden;">
              <button type="button" data-pd-q="-1" style="width:42px;height:44px;font-size:21px;">&minus;</button>
              <span style="min-width:44px;font-size:17px;" data-pd-qval>1</span>
              <button type="button" data-pd-q="1" style="width:42px;height:44px;font-size:21px;">+</button>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <button type="button" class="of-btn of-btn--primary of-pd-buynow" data-pd-buynow{% unless variant.available %} disabled{% endunless %}>{% if variant.available %}Buy Now{% else %}Sold out{% endif %}</button>
            <button type="button" class="of-btn of-btn--outline of-pd-add" data-pd-add{% unless variant.available %} disabled{% endunless %}>Add to Cart</button>
          </div>
        </form>
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}" class="of-btn of-btn--primary" style="width:100%;">Choose the Radio Dry Bag</a>
          <p style="font-size:12.5px;color:var(--of-muted);margin:12px 0 0;text-align:center;line-height:1.5;">Pick the product in the theme editor to enable checkout.</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- ================= SPEC PLATE ================= -->
<section class="of-bg-deep" style="padding:100px 0;">
  <div class="of-container of-container--narrow" style="max-width:1080px;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:26px;" data-reveal>
      <div>
        <p class="of-eyebrow">// Equipment Specifications</p>
        <h2 class="of-display of-text-white" style="font-size:clamp(28px,3.6vw,46px);line-height:0.98;text-transform:uppercase;letter-spacing:-0.5px;">The Spec Plate</h2>
      </div>
      <div style="font-family:var(--of-font-body);font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--of-on-dark-3,#8fa8a8);text-align:right;line-height:1.9;">Batch: OF-001<br>Serial: RDB01-00001</div>
    </div>
    <div class="of-spec">
      <div class="of-spec__head">
        <span style="font-family:var(--of-font-display);font-weight:900;font-size:16px;letter-spacing:1px;text-transform:uppercase;color:#fff;">RDB-01 · Radio Dry Bag</span>
        <span style="font-family:var(--of-font-body);font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--of-deep);background:#fff;padding:5px 12px;border-radius:3px;">Inspect before deployment</span>
      </div>
      <div class="of-spec__grid">
        <div class="of-spec__cell"><div class="of-spec__key">Body</div><div class="of-spec__val">420D ripstop nylon, TPU-laminated with PU coat</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Construction</div><div class="of-spec__val">Fully RF-welded seams — no thread, no glue</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Closure</div><div class="of-spec__val">TRU ZIP® self-healing waterproof zipper</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Protection</div><div class="of-spec__val">Waterproof · Dustproof · Sandproof</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Carry</div><div class="of-spec__val">Secure low-profile cross-body harness + molded EVA back</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Interior</div><div class="of-spec__val">14¼" × 3¾" × 2¼" — fits radio body &amp; antenna</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Fits</div><div class="of-spec__val">Handheld radios and other critical gear</div></div>
        <div class="of-spec__cell"><div class="of-spec__key">Designed for</div><div class="of-spec__val">Coastal rescue operations · tested at Ocean Beach, CA</div></div>
      </div>
    </div>
    <p style="font-family:var(--of-font-body);font-size:12px;letter-spacing:1px;color:var(--of-on-dark-3,#8fa8a8);margin:20px 0 0;text-align:center;text-transform:uppercase;">Retail, agency &amp; bulk-order pricing available on request</p>
  </div>
</section>

<!-- ================= THE BREAKDOWN (callouts) ================= -->
<section class="of-bg-light" style="padding:80px 0 96px;">
  <div class="of-container of-container--narrow" style="max-width:1120px;">
    <div style="text-align:center;max-width:640px;margin:0 auto 56px;" data-reveal>
      <p class="of-eyebrow" style="font-family:var(--of-font-body);">// The Breakdown</p>
      <h2 class="of-display" style="font-size:clamp(30px,4vw,52px);line-height:0.98;text-transform:uppercase;letter-spacing:-0.5px;">Every part, engineered.</h2>
    </div>

    <div class="of-callouts" data-reveal>
      <div class="of-callouts__col of-callouts__col--left">
        <div class="of-callout of-callout--left">
          <div><h3 class="of-callout__title">Clear Operating Window</h3><p class="of-callout__body">See the display and work the radio without ever breaking the seal.</p></div>
          <span class="of-leader"><span class="of-leader__line"></span><span class="of-leader__arrow of-leader__arrow--r"></span></span>
        </div>
        <div class="of-callout of-callout--left">
          <div><h3 class="of-callout__title">RF-Welded Waterproof Shell</h3><p class="of-callout__body">420D ripstop nylon, fused seams — no thread, no glue, no failure points.</p></div>
          <span class="of-leader"><span class="of-leader__line"></span><span class="of-leader__arrow of-leader__arrow--r"></span></span>
        </div>
        <div class="of-callout of-callout--left">
          <div><h3 class="of-callout__title">Padded Branded Harness</h3><p class="of-callout__body">Contoured shoulder yoke spreads the load and stays put in the surf.</p></div>
          <span class="of-leader"><span class="of-leader__line"></span><span class="of-leader__arrow of-leader__arrow--r"></span></span>
        </div>
      </div>
      <div class="of-callouts__img">
        <div style="position:absolute;inset:10px;background:url('{{ bag_img }}') center/contain no-repeat;"></div>
      </div>
      <div class="of-callouts__col of-callouts__col--right">
        <div class="of-callout of-callout--right">
          <span class="of-leader"><span class="of-leader__arrow of-leader__arrow--l"></span><span class="of-leader__line"></span></span>
          <div><h3 class="of-callout__title">TRU ZIP® Self-Healing Zipper</h3><p class="of-callout__body">Waterproof closure that reseals with a single slide, even wet-handed.</p></div>
        </div>
        <div class="of-callout of-callout--right">
          <span class="of-leader"><span class="of-leader__arrow of-leader__arrow--l"></span><span class="of-leader__line"></span></span>
          <div><h3 class="of-callout__title">Quick-Release Buckle</h3><p class="of-callout__body">Side-release buckle drops the bag off fast when seconds count.</p></div>
        </div>
        <div class="of-callout of-callout--right">
          <span class="of-leader"><span class="of-leader__arrow of-leader__arrow--l"></span><span class="of-leader__line"></span></span>
          <div><h3 class="of-callout__title">Adjustable Chest Strap</h3><p class="of-callout__body">Cinches the bag flat to your body so it never swings or shifts.</p></div>
        </div>
      </div>
    </div>

    <div class="of-pd-trio" data-reveal>
      <p class="of-eyebrow" style="font-family:var(--of-font-body);color:var(--of-muted);text-align:center;margin:0 0 22px;">// In the details</p>
      <div class="of-pd-trio__grid">
        <div class="of-pd-trio__item">
          <div class="of-pd-trio__media"><img src="{{ img_harness }}" alt="Padded branded harness" loading="lazy"></div>
          <h3 class="of-pd-trio__title">Padded Harness</h3>
          <p class="of-pd-trio__body">Contoured shoulder yoke, embossed with the Ocean Forged mark.</p>
        </div>
        <div class="of-pd-trio__item">
          <div class="of-pd-trio__media"><img src="{{ img_anchor }}" alt="Reinforced anchor point" loading="lazy"></div>
          <h3 class="of-pd-trio__title">Anchor Point</h3>
          <p class="of-pd-trio__body">Welded triangle ties the harness to the waist strap.</p>
        </div>
        <div class="of-pd-trio__item">
          <div class="of-pd-trio__media"><img src="{{ img_window }}" alt="Clear operating window" loading="lazy"></div>
          <h3 class="of-pd-trio__title">Clear Window</h3>
          <p class="of-pd-trio__body">Work the radio and read the display without breaking the seal.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= WHO IT'S FOR ================= -->
<section class="of-bg-white" style="padding:100px 0;">
  <div class="of-container">
    <div style="max-width:720px;margin:0 auto 52px;text-align:center;" data-reveal>
      <p class="of-eyebrow" style="font-family:var(--of-font-body);">// Who It's For</p>
      <h2 class="of-display" style="font-size:clamp(30px,4vw,52px);line-height:1.0;margin:0 0 18px;text-transform:uppercase;letter-spacing:-0.5px;">Built for the people the ocean tests.</h2>
      <p style="font-size:17px;line-height:1.65;color:var(--of-ink-soft);margin:0;">Designed for lifeguards and professionals operating in harsh environments where reliable radio protection is critical. Comfortable enough for all-day wear.</p>
    </div>
    <div class="of-pd-who">
      <div class="of-pd-who__card" data-reveal>
        <div class="of-pd-who__ph"><span>[ lifeguard photo ]</span></div>
        <h3 class="of-pd-who__title">Lifeguards</h3>
        <p class="of-pd-who__body">Keep radios dry and reachable through every rescue, all day on the sand and in the surf. The bag the product was born from.</p>
      </div>
      <div class="of-pd-who__card" data-reveal>
        <div class="of-pd-who__ph"><span>[ first responder photo ]</span></div>
        <h3 class="of-pd-who__title">First Responders</h3>
        <p class="of-pd-who__body">Reliable radio protection in the harshest environments, so your equipment is ready the moment it matters most.</p>
      </div>
      <div class="of-pd-who__card" data-reveal>
        <div class="of-pd-who__ph"><span>[ surf rescue photo ]</span></div>
        <h3 class="of-pd-who__title">Surf &amp; Water Rescue</h3>
        <p class="of-pd-who__body">Built for pounding surf, salt and sand. Sealed protection that takes the impact and keeps your radio working.</p>
      </div>
      <div class="of-pd-who__card" data-reveal>
        <div class="of-pd-who__ph"><span>[ marine pro photo ]</span></div>
        <h3 class="of-pd-who__title">Marine &amp; Harbor Pros</h3>
        <p class="of-pd-who__body">Dependable on deck and in the spray. A low-profile harness that stays out of the way until you reach for it.</p>
      </div>
      <div class="of-pd-who__card" data-reveal>
        <div class="of-pd-who__ph"><span>[ water sports photo ]</span></div>
        <h3 class="of-pd-who__title">Water Sports &amp; Recreation</h3>
        <p class="of-pd-who__body">Kayakers, kite surfers, boaters, paddlers — anyone on the water who needs a radio, phone or keys to stay dry and within reach.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= BULK / TEAM ORDERS ================= -->
<section class="of-pd-bulk" style="background-image:linear-gradient(90deg, rgba(15,36,35,0.95) 0%, rgba(15,36,35,0.74) 58%, rgba(15,36,35,0.42) 100%), url('{{ ocean_img }}');">
  <div class="of-container">
    <div style="max-width:600px;" data-reveal>
      <p class="of-eyebrow">// Bulk &amp; Team Orders</p>
      <h2 class="of-display of-text-white" style="font-size:clamp(30px,4.4vw,56px);line-height:1.0;margin:0 0 18px;text-transform:uppercase;letter-spacing:-0.5px;">Outfitting a team?</h2>
      <p class="of-lede" style="color:var(--of-on-dark);margin:0 0 30px;max-width:46ch;">We work with agencies and patrols to gear up entire units — with volume pricing and priority lead times built for your unit.</p>
      <a href="{{ section.settings.bulk_link | default: '/pages/pre-sale' }}" class="of-btn of-btn--primary">Team Orders &rarr;</a>
    </div>
  </div>
</section>

<style>
  .of-bg-deep{background:var(--of-deep,#15302f);}
  .of-bg-white{background:#fff;}
  .of-pd-tagline{font-family:var(--of-font-display);font-weight:700;color:var(--of-on-dark,#dbe7e5);font-size:clamp(16px,1.6vw,22px);margin:16px 0 0;text-transform:uppercase;letter-spacing:0.5px;max-width:34ch;padding-bottom:46px;border-bottom:1px solid rgba(143,168,168,0.25);}

  .of-pd-buy{display:grid;grid-template-columns:1.05fr 0.95fr;gap:44px;align-items:stretch;}
  .of-pd-buy__media{border-radius:10px;overflow:hidden;border:1px solid rgba(143,168,168,0.25);position:relative;min-height:420px;background-size:cover;background-position:center 28%;}
  .of-pd-buy__tag{position:absolute;left:0;bottom:0;padding:14px 20px;background:linear-gradient(0deg, rgba(15,36,35,0.9), transparent);width:100%;display:flex;align-items:center;gap:12px;}
  .of-pd-buy__card{background:#fff;border-radius:10px;padding:38px 36px;display:flex;flex-direction:column;box-shadow:0 30px 70px rgba(0,0,0,0.4);}
  .of-pd-chip{font-family:var(--of-font-body);font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--of-ink-soft);border:1px solid rgba(21,48,47,0.18);padding:5px 10px;border-radius:3px;}
  .of-pd-chip--solid{color:var(--of-deep);background:rgba(224,63,26,0.14);border:none;}
  .of-pd-form{margin-top:auto;}
  .of-pd-buynow{padding:18px;font-size:16px;}
  .of-pd-add{padding:15px;font-size:15px;}
  .of-pd-add::after{content:none;}

  .of-spec{border:1px solid rgba(143,168,168,0.3);border-radius:8px;overflow:hidden;background:var(--of-deeper,#0f2423);}
  .of-spec__head{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 24px;background:var(--of-orange);flex-wrap:wrap;}
  .of-spec__grid{display:grid;grid-template-columns:repeat(2,1fr);}
  .of-spec__cell{padding:22px 26px;border-bottom:1px solid rgba(143,168,168,0.18);}
  .of-spec__cell:nth-child(odd){border-right:1px solid rgba(143,168,168,0.18);}
  .of-spec__cell:nth-last-child(-n+2){border-bottom:none;}
  .of-spec__key{font-family:var(--of-font-body);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--of-orange-lt,#ff6a3d);margin-bottom:8px;}
  .of-spec__val{font-family:var(--of-font-body);font-size:15.5px;font-weight:600;color:#eef2f0;line-height:1.55;}

  .of-callouts{display:grid;grid-template-columns:1fr 1.02fr 1fr;gap:24px;align-items:center;max-width:1060px;margin:0 auto;}
  .of-callouts__col{display:flex;flex-direction:column;gap:44px;}
  .of-callout{display:flex;align-items:center;gap:16px;}
  .of-callout--left{justify-content:flex-end;text-align:right;}
  .of-callout--right{text-align:left;}
  .of-callout__title{font-family:var(--of-font-display);font-weight:800;color:var(--of-deep);font-size:15px;margin:0 0 5px;text-transform:uppercase;letter-spacing:0.3px;}
  .of-callout__body{font-size:12.5px;line-height:1.5;color:var(--of-ink-soft);margin:0;text-transform:uppercase;letter-spacing:0.4px;}
  .of-leader{display:flex;align-items:center;flex-shrink:0;}
  .of-leader__line{width:38px;height:2px;background:var(--of-orange);display:block;}
  .of-leader__arrow{width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;}
  .of-leader__arrow--r{border-left:9px solid var(--of-orange);}
  .of-leader__arrow--l{border-right:9px solid var(--of-orange);}
  .of-callouts__img{position:relative;aspect-ratio:1/1;background:#fff;border-radius:16px;border:1px solid #e0e6e4;box-shadow:0 26px 60px rgba(21,48,47,0.12);overflow:hidden;}

  .of-pd-trio{margin:56px auto 0;max-width:840px;text-align:center;}
  .of-pd-trio__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:44px;}
  .of-pd-trio__media{width:100%;aspect-ratio:1/1;border-radius:10px;overflow:hidden;border:1px solid #e0e6e4;background:#f4f6f4;}
  .of-pd-trio__media img{width:100%;height:100%;object-fit:cover;display:block;}
  .of-pd-trio__title{font-family:var(--of-font-display);font-weight:800;font-size:12px;color:var(--of-deep);margin:14px 0 6px;text-transform:uppercase;letter-spacing:0.5px;}
  .of-pd-trio__body{font-size:12px;color:var(--of-ink-soft);line-height:1.5;margin:0;text-transform:uppercase;letter-spacing:0.3px;}

  .of-pd-who{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  .of-pd-who__card{display:flex;flex-direction:column;}
  .of-pd-who__ph{border-radius:8px;overflow:hidden;aspect-ratio:4/3;background:repeating-linear-gradient(45deg,#eceeeb,#eceeeb 16px,#f4f6f4 16px,#f4f6f4 32px);display:flex;align-items:center;justify-content:center;margin-bottom:18px;border:1px solid #e4eae8;}
  .of-pd-who__ph span{font-family:var(--of-font-body);font-size:11px;letter-spacing:1px;color:#a8b8b6;text-transform:uppercase;}
  .of-pd-who__title{font-family:var(--of-font-display);font-weight:800;font-size:20px;margin:0 0 10px;text-transform:uppercase;}
  .of-pd-who__body{font-size:15px;line-height:1.6;color:var(--of-ink-soft);margin:0;}

  .of-pd-bulk{position:relative;background-size:cover;background-position:center;padding:100px 0;}

  @media (max-width:820px){
    .of-pd-buy{grid-template-columns:1fr;}
    .of-callouts{grid-template-columns:1fr;gap:34px;}
    .of-callout--left,.of-callout--right{justify-content:flex-start;text-align:left;flex-direction:row-reverse;}
    .of-callout--left .of-leader,.of-callout--right .of-leader{transform:scaleX(-1);}
    .of-callouts__img{max-width:360px;margin:0 auto;order:-1;}
    .of-pd-trio__grid{gap:22px;}
    .of-pd-who{grid-template-columns:1fr 1fr;}
  }
  @media (max-width:560px){ .of-pd-who{grid-template-columns:1fr;} .of-spec__grid{grid-template-columns:1fr;} .of-spec__cell:nth-child(odd){border-right:none;} }
</style>

<script>
(function () {
  var root = document.currentScript && document.currentScript.previousElementSibling;
  var form = document.querySelector('[data-of-pd-form]');
  if (!form) return;
  var qty = 1;
  var qval = form.querySelector('[data-pd-qval]');
  var variantId = form.getAttribute('data-variant');

  form.addEventListener('click', function (e) {
    var step = e.target.closest('[data-pd-q]');
    if (step) { qty = Math.max(1, Math.min(99, qty + parseInt(step.getAttribute('data-pd-q'), 10))); if (qval) qval.textContent = qty; return; }

    var add = e.target.closest('[data-pd-add]');
    if (add && !add.disabled) {
      if (window.OFCart) { add.disabled = true; add.textContent = 'Adding…'; window.OFCart.add(variantId, qty).then(function () { add.disabled = false; add.textContent = 'Add to Cart'; }).catch(function () { add.disabled = false; add.textContent = 'Add to Cart'; }); }
      else { fallbackAdd(false); }
      return;
    }
    var buy = e.target.closest('[data-pd-buynow]');
    if (buy && !buy.disabled) { fallbackAdd(true); return; }
  });

  function fallbackAdd(checkout) {
    fetch('/cart/add.js', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    }).then(function () {
      if (checkout) window.location.href = '/checkout';
      else if (window.OFCart && window.OFCart.open) window.OFCart.open();
      else window.location.href = '/cart';
    });
  }
})();
</script>

