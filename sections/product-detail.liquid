<script>
(function () {
  // buy-box qty + add/buy
  var form = document.querySelector('[data-of-pd-form]');
  if (form) {
    var qty = 1;
    var qval = form.querySelector('[data-pd-qval]');
    var variantId = form.getAttribute('data-variant');

    form.addEventListener('click', function (e) {
      var step = e.target.closest('[data-pd-q]');
      if (step) { qty = Math.max(1, Math.min(99, qty + parseInt(step.getAttribute('data-pd-q'), 10))); if (qval) qval.textContent = qty; return; }

      var add = e.target.closest('[data-pd-add]');
      if (add && !add.disabled) {
        if (window.OFCart) { add.disabled = true; add.textContent = 'Adding…'; window.OFCart.add(variantId, qty).then(function () { add.disabled = false; add.textContent = 'Add to Cart'; }).catch(function () { add.disabled = false; add.textContent = 'Add to Cart'; }); }
        else { fallbackAdd(false); }
        return;
      }
      var buy = e.target.closest('[data-pd-buynow]');
      if (buy && !buy.disabled) { fallbackAdd(true); return; }
    });

    function fallbackAdd(checkout) {
      fetch('/cart/add.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      }).then(function () {
        if (checkout) window.location.href = '/checkout';
        else if (window.OFCart && window.OFCart.open) window.OFCart.open();
        else window.location.href = '/cart';
      });
    }
  }

  // buy-box photo carousel
  var carousel = document.querySelector('[data-pd-carousel]');
  if (carousel) {
    var slides = [
      { url: {{ carousel1 | json }}, pos: 'center 46%', zoom: '150%', label: 'On the back' },
      { url: {{ carousel2 | json }}, pos: 'center 52%', zoom: '190%', label: 'Cross-body carry' },
      { url: {{ carousel3 | json }}, pos: 'center 58%', zoom: '190%', label: 'In the field' }
    ];
    var idx = 0;
    var slideEl = carousel.querySelector('[data-pd-slide]');
    var labelEl = carousel.querySelector('[data-pd-label]');
    var dots = carousel.querySelectorAll('[data-pd-dot]');
    function render() {
      var s = slides[idx];
      slideEl.style.backgroundImage = "url('" + s.url + "')";
      slideEl.style.backgroundPosition = s.pos;
      slideEl.style.backgroundSize = s.zoom;
      if (labelEl) labelEl.textContent = s.label;
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
    }
    carousel.querySelector('[data-pd-prev]').addEventListener('click', function () { idx = (idx + slides.length - 1) % slides.length; render(); });
    carousel.querySelector('[data-pd-next]').addEventListener('click', function () { idx = (idx + 1) % slides.length; render(); });
    dots.forEach(function (d, i) { d.addEventListener('click', function () { idx = i; render(); }); });
  }

  // FAQ accordion
  var faqList = document.querySelector('[data-of-faq]');
  if (faqList) {
    faqList.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-faq-toggle]');
      if (!btn) return;
      var item = btn.closest('.of-faq-item');
      var wasOpen = item.classList.contains('is-open');
      faqList.querySelectorAll('.of-faq-item.is-open').forEach(function (openItem) {
        openItem.classList.remove('is-open');
        openItem.querySelector('.of-faq-a').style.maxHeight = '0px';
      });
      if (!wasOpen) {
        item.classList.add('is-open');
        var panel = item.querySelector('.of-faq-a');
        panel.style.maxHeight = panel.scrollHeight + 40 + 'px';
      }
    });
  }
})();
</script>

