{%- comment -%}
  Ocean Forged — Product detail (Radio Dry Bag).
  Buy box adds a real Shopify product/variant to the global cart drawer (window.OFCart).
  Pick the product in the theme editor: Product page → Buy box → Product.
{%- endcomment -%}
{%- liquid
  assign product = section.settings.product
  assign variant = product.selected_or_first_available_variant
  assign wave_img = 'ocean-wave-hero.jpg' | asset_url
  assign jetski_img = 'bag-jetski.jpeg' | asset_url
  assign group_img = 'lifeguards-sfo-group.jpeg' | asset_url
  assign kite_img = 'watersports-kite.jpg' | asset_url
  assign diver_img = 'diver-woman-fins-2.jpeg' | asset_url
  assign ocean_img = 'ocean-hero.jpg' | asset_url
  assign img_harness = 'detail-harness.png' | asset_url
  assign img_anchor  = 'detail-anchor.png' | asset_url
  assign img_window  = 'detail-window.png' | asset_url
  assign img_zipper  = 'detail-zipper.png' | asset_url
  assign carousel1 = 'lifestyle-back.jpg' | asset_url
  assign carousel2 = 'lifestyle-side.jpg' | asset_url
  assign carousel3 = 'lifestyle-front.jpg' | asset_url
-%}

<!-- ================= PRODUCT HERO ================= -->
<section style="background:#15302f; padding:48px 32px 0;">
  <div class="of-container">
    <h1 class="of-display of-text-white" style="font-size:clamp(32px,4.4vw,60px);line-height:0.9;letter-spacing:-1px;margin:0;text-transform:uppercase;" data-reveal>{{ section.settings.title | default: 'Radio Dry Bag' }}</h1>
    <p class="of-eyebrow" style="margin:14px 0 0;" data-reveal>{{ section.settings.eyebrow | default: 'Ocean Forged · Product 01' }}</p>
    <p style="font-family:var(--of-font-display);font-weight:700;color:#dbe7e5;font-size:clamp(14px,1.4vw,18px);margin:12px 0 0;text-transform:uppercase;letter-spacing:0.5px;max-width:44ch;padding-bottom:28px;border-bottom:1px solid rgba(143,168,168,0.25);" data-reveal>{{ section.settings.subtitle | default: 'Made by lifeguards. Built for real world rescues.' }}</p>
  </div>
</section>

<!-- ================= BUY BOX ================= -->
<section style="position:relative;background-image:linear-gradient(180deg, rgba(15,36,35,0.86) 0%, rgba(15,36,35,0.94) 100%), url('{{ wave_img }}');background-size:cover;background-position:center;padding:56px 32px 44px;">
  <div style="max-width:920px;margin:0 auto;">
    <div class="of-pd-buy">
      <div class="of-pd-buy__media" data-pd-carousel>
        <div class="of-pd-buy__slide" data-pd-slide style="background-image:url('{{ carousel1 }}'); background-size:150%; background-position:center 46%;"></div>
        <button type="button" class="of-pd-arrow of-pd-arrow--l" data-pd-prev aria-label="Previous photo">&lsaquo;</button>
        <button type="button" class="of-pd-arrow of-pd-arrow--r" data-pd-next aria-label="Next photo">&rsaquo;</button>
        <div class="of-pd-buy__caption">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
            <span style="font-family:var(--of-font-body);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--of-orange-lt,#ff6a3d);">RDB-01</span>
            <span style="font-family:var(--of-font-body);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--of-on-dark-3,#8fa8a8);" data-pd-label>On the back</span>
          </div>
          <div style="display:flex;justify-content:center;gap:8px;" data-pd-dots>
            <button type="button" class="of-pd-dot is-active" data-pd-dot="0" aria-label="Show photo 1"></button>
            <button type="button" class="of-pd-dot" data-pd-dot="1" aria-label="Show photo 2"></button>
            <button type="button" class="of-pd-dot" data-pd-dot="2" aria-label="Show photo 3"></button>
          </div>
        </div>
      </div>
      <div class="of-pd-buy__card">
        <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
          <span class="of-pd-chip of-pd-chip--solid">{% if variant.available %}In Stock{% else %}Made to order{% endif %}</span>
          <span class="of-pd-chip">Ready to Ship</span>
        </div>
        <h2 class="of-display" style="font-size:30px;margin:0 0 6px;text-transform:uppercase;letter-spacing:-0.5px;line-height:1;">{{ product.title | default: 'Radio Dry Bag' | upcase }}</h2>
        <p style="font-family:var(--of-font-body);font-size:14px;color:var(--of-ink-soft);margin:0 0 20px;line-height:1.55;text-transform:uppercase;letter-spacing:0.4px;">Fast Loading · RF-Welded · Waterproof · Cross-Body Harness</p>
        <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:22px;">
          <span class="of-display" style="font-size:44px;color:var(--of-orange);letter-spacing:-1px;">{% if product != blank %}{{ variant.price | money }}{% else %}$120{% endif %}</span>
          <span style="font-family:var(--of-font-body);font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--of-muted);">per unit</span>
        </div>

        {%- if product != blank -%}
        <form class="of-pd-form" data-of-pd-form data-variant="{{ variant.id }}">
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:18px;">
            <span style="font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--of-deep);">Qty</span>
            <div class="of-step" style="border:2px solid rgba(21,48,47,0.2);border-radius:6px;overflow:hidden;">
              <button type="button" data-pd-q="-1" style="width:42px;height:44px;font-size:21px;">&minus;</button>
              <span style="min-width:44px;font-size:17px;" data-pd-qval>1</span>
              <button type="button" data-pd-q="1" style="width:42px;height:44px;font-size:21px;">+</button>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <button type="button" class="of-btn of-btn--primary of-pd-buynow" data-pd-buynow{% unless variant.available %} disabled{% endunless %}>{% if variant.available %}Buy Now{% else %}Sold out{% endif %}</button>
            <button type="button" class="of-btn of-btn--outline of-pd-add" data-pd-add{% unless variant.available %} disabled{% endunless %}>Add to Cart</button>
          </div>
        </form>
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}" class="of-btn of-btn--primary" style="width:100%;">Choose the Radio Dry Bag</a>
          <p style="font-size:12.5px;color:var(--of-muted);margin:12px 0 0;text-align:center;line-height:1.5;">Pick the product in the theme editor to enable checkout.</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

