<section class="of-section of-bg-light">
  <div class="of-container" style="max-width:1100px;">
    <h2 class="of-display of-h2" style="text-align:center;margin-bottom:50px;" data-reveal>{{ section.settings.heading | default: 'Why join early' }}</h2>
    <div class="of-grid of-grid--3">
      {%- for block in section.blocks -%}
        <div style="text-align:center;padding:10px;" data-reveal {{ block.shopify_attributes }}>
          <div style="font-family:var(--of-font-display);font-weight:900;font-size:38px;color:var(--of-orange);margin-bottom:14px;">{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <h3 style="font-family:var(--of-font-display);font-weight:800;font-size:19px;margin:0 0 10px;text-transform:uppercase;">{{ block.settings.title }}</h3>
          <p style="font-size:15px;line-height:1.6;color:var(--of-ink-soft);margin:0;">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Numbered points",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why join early" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "First Access" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{
    "name": "Numbered points",
    "blocks": [
      { "type": "point", "settings": { "number": "01", "title": "First Access", "body": "Be first in line when the first production run ships." } },
      { "type": "point", "settings": { "number": "02", "title": "Follow the Build", "body": "Get behind-the-scenes notes from testing and production." } },
      { "type": "point", "settings": { "number": "03", "title": "Shape What's Next", "body": "Your feedback directly informs the next Ocean Forged products." } }
    ]
  }]
}
{% endschema %}
