<section class="of-bg-deep" style="padding:96px 0 70px;">
  <div class="of-container of-container--wide">
    <p class="of-eyebrow" data-reveal>Your Cart</p>
    <h1 class="of-display of-h1 of-text-white" data-reveal>Cart</h1>
  </div>
</section>

<section class="of-section of-bg-light">
  <div class="of-container" style="max-width:960px;">
    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        <div style="background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 12px 40px rgba(21,48,47,0.06);">
          {%- for item in cart.items -%}
            <div style="display:grid;grid-template-columns:88px 1fr auto auto;gap:20px;align-items:center;padding:22px 26px;{% unless forloop.last %}border-bottom:1px solid #e4eae8;{% endunless %}">
              <div style="width:88px;height:88px;border-radius:6px;overflow:hidden;background:#eef2f1;">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:100%;height:100%;object-fit:cover;">{%- endif -%}
              </div>
              <div>
                <a href="{{ item.url }}" style="font-family:var(--of-font-display);font-weight:800;font-size:17px;text-transform:uppercase;color:var(--of-deep);">{{ item.product.title }}</a>
                {%- unless item.variant.title contains 'Default' -%}<div style="font-size:14px;color:var(--of-muted);margin-top:4px;">{{ item.variant.title }}</div>{%- endunless -%}
              </div>
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="of-field" style="width:70px;text-align:center;">
              <div style="font-weight:700;color:var(--of-deep);min-width:80px;text-align:right;">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>

        <div style="display:flex;justify-content:space-between;align-items:center;gap:24px;margin-top:32px;flex-wrap:wrap;">
          <button type="submit" name="update" class="of-btn of-btn--outline">Update Cart</button>
          <div style="text-align:right;">
            <div style="font-size:14px;color:var(--of-muted);text-transform:uppercase;letter-spacing:1px;">Subtotal</div>
            <div style="font-family:var(--of-font-display);font-weight:900;font-size:28px;color:var(--of-deep);">{{ cart.total_price | money }}</div>
          </div>
        </div>
        <div style="margin-top:24px;text-align:right;">
          <button type="submit" name="checkout" class="of-btn of-btn--primary" style="font-size:16px;padding:18px 48px;">Checkout</button>
        </div>
        <p style="font-size:13px;color:var(--of-muted);margin:16px 0 0;text-align:right;">Taxes and shipping calculated at checkout.</p>
      {%- endform -%}
    {%- else -%}
      <div style="text-align:center;padding:60px 0;">
        <p style="font-size:18px;color:var(--of-ink-soft);margin:0 0 28px;">Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="of-btn of-btn--primary">Shop the Radio Dry Bag</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
