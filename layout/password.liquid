<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>
    {%- if settings.favicon != blank -%}<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">{%- endif -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {%- style -%}
      :root { --of-deep: {{ settings.color_deep | default: '#15302f' }}; --of-deeper: {{ settings.color_deeper | default: '#0f2423' }}; --of-orange: {{ settings.color_accent | default: '#E03F1A' }}; --of-light: {{ settings.color_light | default: '#f2f5f4' }}; }
    {%- endstyle -%}
    {{ content_for_header }}
  </head>
  <body>
    <section style="min-height:100vh;display:flex;align-items:center;justify-content:center;background-image:linear-gradient(rgba(21,48,47,0.86), rgba(21,48,47,0.94)), url('{{ 'ocean-hero.jpg' | asset_url }}');background-size:cover;background-position:center;">
      <div class="of-container" style="text-align:center;max-width:560px;">
        {%- if shop.logo != blank -%}<img src="{{ shop.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="margin:0 auto 28px;max-height:70px;width:auto;">{%- else -%}<img src="{{ 'logo-lockup-white.png' | asset_url }}" alt="{{ shop.name }}" style="margin:0 auto 28px;max-height:90px;width:auto;">{%- endif -%}
        <p class="of-eyebrow of-eyebrow--light">Coming Soon</p>
        <h1 class="of-display of-text-white" style="font-size:clamp(36px,5vw,64px);line-height:0.98;margin-bottom:20px;">{{ page_title }}</h1>
        <div style="color:var(--of-on-dark);font-size:18px;line-height:1.6;margin-bottom:32px;">{{ shop.password_message | default: 'The first wave is almost here.' }}</div>
        <div style="max-width:400px;margin:0 auto;">
          {%- form 'storefront_password' -%}
            <div style="display:flex;gap:10px;">
              <input type="password" name="password" placeholder="Enter password" class="of-field">
              <button type="submit" class="of-btn of-btn--primary">Enter</button>
            </div>
            {%- if form.errors -%}<p style="color:#ffb3a3;margin:12px 0 0;font-size:14px;">{{ form.errors | default_errors }}</p>{%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </section>
  </body>
</html>
