<section class="of-section of-bg-light" style="min-height:60vh;">
  <div class="of-container" style="max-width:440px;">
    <p class="of-eyebrow">Account</p>
    <h1 class="of-display" style="font-size:34px;margin-bottom:24px;">Activate your account</h1>
    {%- form 'activate_customer_password' -%}
      {%- if form.errors -%}<p style="color:#9a2a12;background:#fbeae7;padding:14px;border-radius:6px;margin-bottom:16px;">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div style="display:flex;flex-direction:column;gap:12px;">
        <input type="password" name="customer[password]" placeholder="Password" class="of-field" required>
        <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" class="of-field" required>
        <button type="submit" class="of-btn of-btn--primary">Activate account</button>
        <button type="submit" name="decline" class="of-btn of-btn--outline">Decline invitation</button>
      </div>
    {%- endform -%}
  </div>
</section>
