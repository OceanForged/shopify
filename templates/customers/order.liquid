<section class="of-section of-bg-light" style="min-height:60vh;">
  <div class="of-container" style="max-width:820px;">
    <p class="of-eyebrow">Order</p>
    <h1 class="of-display" style="font-size:34px;margin-bottom:6px;">{{ order.name }}</h1>
    <p style="color:var(--of-ink-soft);margin:0 0 28px;">Placed {{ order.created_at | date: '%B %-d, %Y' }} · {{ order.financial_status_label }} · {{ order.fulfillment_status_label }}</p>

    <div style="background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 12px 40px rgba(21,48,47,0.06);">
      {%- for line in order.line_items -%}
        <div style="display:grid;grid-template-columns:1fr auto auto;gap:16px;padding:18px 24px;{% unless forloop.last %}border-bottom:1px solid #e4eae8;{% endunless %}align-items:center;">
          <div>
            <div style="font-weight:700;color:var(--of-deep);">{{ line.title }}</div>
            <div style="font-size:14px;color:var(--of-muted);">Qty {{ line.quantity }}</div>
          </div>
          <span style="color:var(--of-ink-soft);">{{ line.price | money }}</span>
          <span style="font-weight:700;text-align:right;">{{ line.final_line_price | money }}</span>
        </div>
      {%- endfor -%}
    </div>

    <div style="display:flex;justify-content:flex-end;margin-top:24px;">
      <div style="text-align:right;">
        <div style="color:var(--of-ink-soft);margin-bottom:6px;">Subtotal: {{ order.line_items_subtotal_price | money }}</div>
        <div style="color:var(--of-ink-soft);margin-bottom:6px;">Shipping: {{ order.shipping_price | money }}</div>
        <div style="font-family:var(--of-font-display);font-weight:900;font-size:24px;color:var(--of-deep);">Total: {{ order.total_price | money }}</div>
      </div>
    </div>

    <p style="margin-top:28px;"><a href="{{ routes.account_url }}" style="color:var(--of-orange);text-decoration:underline;">&larr; Back to account</a></p>
  </div>
</section>
