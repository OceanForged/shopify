<section class="of-section of-bg-light" style="min-height:70vh;">
  <div class="of-container" style="max-width:440px;">
    <p class="of-eyebrow">Account</p>
    <h1 class="of-display" style="font-size:36px;margin-bottom:24px;">Create account</h1>
    {%- form 'create_customer' -%}
      {%- if form.errors -%}<p style="color:#9a2a12;background:#fbeae7;padding:14px;border-radius:6px;margin-bottom:16px;">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div style="display:flex;flex-direction:column;gap:12px;">
        <input type="text" name="customer[first_name]" placeholder="First name" class="of-field">
        <input type="text" name="customer[last_name]" placeholder="Last name" class="of-field">
        <input type="email" name="customer[email]" placeholder="Email" class="of-field" required>
        <input type="password" name="customer[password]" placeholder="Password" class="of-field" required>
        <button type="submit" class="of-btn of-btn--primary">Create account</button>
      </div>
    {%- endform -%}
    <p style="margin-top:18px;font-size:14px;">Already have an account? <a href="{{ routes.account_login_url }}" style="color:var(--of-orange);text-decoration:underline;">Sign in</a></p>
  </div>
</section>
